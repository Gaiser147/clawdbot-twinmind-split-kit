{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/twinmind-split-kit/migration.schema.json",
  "title": "TwinMind Split Migration Manifest",
  "type": "object",
  "required": [
    "migration_id",
    "created_at_utc",
    "mode",
    "target_config_path",
    "backup_config_path",
    "before_checksum",
    "after_checksum",
    "patched_fields",
    "status"
  ],
  "properties": {
    "migration_id": {"type": "string"},
    "created_at_utc": {"type": "string"},
    "mode": {"type": "string", "enum": ["apply"]},
    "target_config_path": {"type": "string"},
    "target_env_path": {"type": "string"},
    "backup_config_path": {"type": "string"},
    "backup_env_path": {"type": "string"},
    "before_checksum": {"type": "string"},
    "after_checksum": {"type": "string"},
    "patch_env": {"type": "boolean"},
    "force_split_default": {"type": "boolean"},
    "kit_root": {"type": "string"},
    "status": {"type": "string", "enum": ["applied"]},
    "patched_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "new"],
        "properties": {
          "path": {"type": "string"},
          "old": {},
          "new": {}
        }
      }
    }
  }
}
